# Comma-separated list of proxy URLs (optional)
# Format: http://user:pass@host:port
PROXY_LIST=http://proxy1:8080,http://proxy2:8080

# Comma-separated list of target URLs to scrape
TARGET_URLS=https://example.com/product-1,https://example.com/product-2

# Number of retry attempts per URL
MAX_RETRIES=3

# Seconds to wait between retries (multiplied by attempt number)
RETRY_DELAY=2.0

# Directory where CSV output files are saved
OUTPUT_DIR=output
